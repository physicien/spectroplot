NAME = FRQ_tungsten_hexacarbonyl_f.inp
|  1> ! B3LYP/G def2-SVP  DefGrid3 ExtremeSCF FREQ
|  2> # DFT functional:   B3LYP/G
|  3> # Basis:            def2-SVP
|  4> %maxcore 750
|  5> %pal nprocs 22
|  6> end
|  7> %base "FRQ_tungsten_hexacarbonyl_f"
|  8> %scf
|  9>       Guess         MORead
| 10>       MOInp         "OPT_tungsten_hexacarbonyl_f.gbw"
| 11> end
| 12> *xyzfile 0 1 OPT_tungsten_hexacarbonyl_f.xyz
| 13> 
| 14>                          ****END OF INPUT****
